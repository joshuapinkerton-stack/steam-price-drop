{
    "$schema": "https://apify.com/schemas/v1/output.ide.json",
    "actorOutputSchemaVersion": 1,
    "title": "Steam Price Drop Output",
    "description": "Game pricing records.",
    "properties": {
        "title": {
            "type": "string",
            "title": "Title",
            "template": "{{item.title}}"
        },
        "currentPrice": {
            "type": "string",
            "title": "Current Price",
            "template": "{{item.currentPrice}}"
        },
        "discountPercent": {
            "type": "string",
            "title": "Discount Percent",
            "template": "{{item.discountPercent}}"
        },
        "releaseDate": {
            "type": "string",
            "title": "Release Date",
            "template": "{{item.releaseDate}}"
        },
        "platforms": {
            "type": "string",
            "title": "Platforms",
            "template": "{{item.platforms}}"
        },
        "appUrl": {
            "type": "string",
            "title": "App URL",
            "template": "{{item.appUrl}}"
        },
        "detectedAt": {
            "type": "string",
            "title": "Detected At",
            "template": "{{item.detectedAt}}"
        }
    }
}
